# ==============================================================================
# Configuración de Supabase (Solo Claves de Cliente / Públicas)
# ==============================================================================
# Copiar este archivo a `.env` y completar con las credenciales correspondientes.
# 
# IMPORTANTE: 
# 1. NUNCA subas el archivo `.env` real al repositorio de Git.
# 2. NUNCA incluyas la clave `SERVICE_ROLE` o contraseñas de Base de Datos aquí.
#    Esta aplicación móvil solo debe interactuar con las APIs públicas usando la
#    clave anónima (`anon key`) y aplicar políticas de RLS (Row Level Security).

# URL del proyecto de Supabase (ej. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (anon key)
SUPABASE_ANON_KEY=tu-anon-key-aqui
